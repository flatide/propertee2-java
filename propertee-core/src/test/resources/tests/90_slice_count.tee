// Test: SLICE(arr, start, count) — third argument is a count (spec v0.7.0 #6)
data = [10, 20, 30, 40, 50]

PRINT(SLICE(data, 2, 3))
PRINT(SLICE(data, 2, 4))
PRINT(SLICE(data, 4, 10))
PRINT(SLICE(data, 1, 0))
PRINT(SLICE(data, 3))

// Same convention as SUBSTRING and READ_LINES (start + count)
PRINT(SUBSTRING("hello world", 7, 5))
