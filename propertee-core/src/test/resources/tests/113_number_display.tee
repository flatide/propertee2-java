// spec v0.14.0: ECMA-262 Number::toString display — plain in [1e-6, 1e21), exponential outside,
// uniform across PRINT / TO_STRING / JSON_FORMAT.
PRINT(0.0001)
PRINT(15000000.5)
PRINT(TO_NUMBER("6000000000"))
PRINT(TO_NUMBER("123456789012345680000"))
PRINT(TO_NUMBER("1000000000000000"))
PRINT(UNWRAP(JSON_PARSE("1e21")))
PRINT(UNWRAP(JSON_PARSE("1e-7")))
PRINT(UNWRAP(JSON_PARSE("1e300")))
PRINT(0.1 + 0.2)
PRINT(10 / 3)
PRINT(0.000001)
PRINT(TO_STRING(0.0001))
PRINT(JSON_FORMAT(TO_NUMBER("6000000000")))
PRINT(JSON_FORMAT(0.0001))
PRINT([0.0001, TO_NUMBER("6000000000"), 1234.5678])
