// spec v0.13.0: a blocked function reached via thread spawn fails THAT worker only
function fine() do
    return 7
end
function blocked_fn() do
    return 1
end
multi r do
    thread a: fine()
    thread b: blocked_fn()
end
PRINT("a:", r.a.ok, r.a.value)
PRINT("b:", r.b.ok, r.b.value)
PRINT("run continues")
