// Test: Mixed named and unnamed threads, auto-key behavior
function identity(x) do
    return x
end

multi result do
    thread named: identity(10)
    thread : identity(20)
    thread also_named: identity(30)
    thread : identity(40)
end

// Named access
PRINT("named:", result.named.value)
PRINT("also_named:", result.also_named.value)

// Unnamed threads get auto-key by position (counting only unnamed)
PRINT("pos1:", result."#1".value)
PRINT("pos2:", result."#2".value)

// LEN
PRINT("len:", LEN(result))

// Iterate all
loop key, val in result do
    PRINT(key + ":" + TO_STRING(val.value))
end
