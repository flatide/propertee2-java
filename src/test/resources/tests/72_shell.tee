// Test 72: SHELL and SHELL_CTX require a host-provided TaskRunner in core-only mode

expected = "SHELL() requires a host-provided TaskRunner in this environment"

// 1. One-off command should fail clearly
r = SHELL("echo hello")
if r.ok == false and r.value == expected then
    PRINT("PASS one-off unsupported")
else
    PRINT("FAIL one-off")
end

// 2. Pipe command should fail clearly
r = SHELL("echo 'c b a' | tr ' ' '\n' | sort")
if r.ok == false and r.value == expected then
    PRINT("PASS pipe unsupported")
else
    PRINT("FAIL pipe")
end

// 3. Explicit shell failure still reports unsupported runner first
r = SHELL("exit 1")
if r.ok == false and r.value == expected then
    PRINT("PASS unsupported exit")
else
    PRINT("FAIL unsupported exit")
end

// 4. Context creation still works, execution still fails
ctx = SHELL_CTX("/")
if ctx.ok == true then
    r = SHELL(ctx, "pwd")
    if r.ok == false and r.value == expected then
        PRINT("PASS cwd unsupported")
    else
        PRINT("FAIL cwd cmd")
    end
else
    PRINT("FAIL ctx")
end

// 5. Context with env vars still validates and fails on execute
ctx = SHELL_CTX("/", {"PT_TEST_VAR": "yes"})
if ctx.ok == true then
    r = SHELL(ctx, "echo $PT_TEST_VAR")
    if r.ok == false and r.value == expected then
        PRINT("PASS env unsupported")
    else
        PRINT("FAIL env cmd")
    end
else
    PRINT("FAIL ctx env")
end

// 6. Invalid cwd
ctx = SHELL_CTX("/nonexistent_xyz_dir_12345")
if ctx.ok == false then
    PRINT("PASS invalid cwd")
else
    PRINT("FAIL invalid cwd")
end

// 7. Parallel SHELL in multi block
function shellA() do
    return SHELL("echo thread_a")
end

function shellB() do
    return SHELL("echo thread_b")
end

multi result do
    thread a: shellA()
    thread b: shellB()
end

if result.a.ok == true and result.a.value.ok == false then
    aVal = result.a.value.value
else
    aVal = "error"
end

if result.b.ok == true and result.b.value.ok == false then
    bVal = result.b.value.value
else
    bVal = "error"
end

if aVal == expected and bVal == expected then
    PRINT("PASS multi unsupported")
else
    PRINT("FAIL multi")
end
